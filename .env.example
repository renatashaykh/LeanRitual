# Copy this to .env for local dev (never commit .env to git)

# Required
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: restrict bot to specific Telegram user IDs (comma-separated)
# Leave blank to allow all users
ALLOWED_USER_IDS=123456789

# Optional: your timezone (for date tracking)
USER_TIMEZONE=Europe/London

# Optional: where to store daily logs (default: ./data)
DATA_DIR=data
